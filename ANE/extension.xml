<extension xmlns="http://ns.adobe.com/air/extension/22.0">
  <id>com.fluocode.extensions.billing</id>
  <versionNumber>1.0.0</versionNumber>
  <copyright>2026, Fluocode. All rights reserved.</copyright>
  <description>
		<text xml:lang="en">customized adobe air native extension</text> 
  </description> 
  <platforms>
  
    <platform name="Android-ARM64">
		<applicationDeployment>
			<nativeLibrary>libInAppBilling.jar</nativeLibrary>
			<initializer>com.fluocode.ane.Billing</initializer>
			<finalizer>com.fluocode.ane.Billing</finalizer>
		</applicationDeployment>
    </platform>
  
    <platform name="Android-ARM">
		<applicationDeployment>
			<nativeLibrary>libInAppBilling.jar</nativeLibrary>
			<initializer>com.fluocode.ane.Billing</initializer>
			<finalizer>com.fluocode.ane.Billing</finalizer>
		</applicationDeployment>
    </platform>
	
	<platform name="Android-x86">
		<applicationDeployment>
			<nativeLibrary>libInAppBilling.jar</nativeLibrary>
			<initializer>com.fluocode.ane.Billing</initializer>
			<finalizer>com.fluocode.ane.Billing</finalizer>
		</applicationDeployment>
    </platform>
	
	<platform name="iPhone-ARM">
		<applicationDeployment>
			<nativeLibrary>libInAppBillingANE.a</nativeLibrary>
			<initializer>cinAppBillingExtensionInitializer</initializer>
			<finalizer>inAppBillingExtensionFinalizer</finalizer>
		</applicationDeployment>
	</platform>
	<platform name="iPhone-x86">
		<applicationDeployment>
			<nativeLibrary>libInAppBillingANE.a</nativeLibrary>
			<initializer>cinAppBillingExtensionInitializer</initializer>
			<finalizer>inAppBillingExtensionFinalizer</finalizer>
		</applicationDeployment>
	</platform>
	
	<platform name="default"> 
		<applicationDeployment>
		</applicationDeployment>
	</platform> 
	
  </platforms>
</extension>

